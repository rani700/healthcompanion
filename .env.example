# Google Gemini API key (from Google AI Studio: https://aistudio.google.com/apikey)
# Copy this file to .env and fill in your key. NEVER commit .env.
GEMINI_API_KEY=

# Secret used to sign session tokens (JWT). MUST be set to a long random value
# in production. Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
HC_JWT_SECRET=

# Optional overrides (defaults shown)
# HC_DATA_DIR=./data
# HC_MODEL_GEN=gemini-2.5-flash
# HC_MODEL_EMBED=gemini-embedding-001
# HC_EMBED_DIM=768
# HC_TOKEN_TTL_HOURS=12
